{
  "name": "cassie",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "app"
  ],
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "app:dev": "yarn workspace landing dev",
    "app:build": "yarn workspace landing build",
    "test:js": "ts-mocha -p ./tsconfig.json --timeout 120000 tests/test.ts",
    "test:js:single": "ts-mocha -p ./tsconfig.json --timeout 120000",
    "test:dev": "CASSIE_CLUSTER_URL=${CASSIE_CLUSTER_URL:-https://api.devnet.solana.com} ts-mocha -p ./tsconfig.json --timeout 300000 tests/dev.ts"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.0",
    "@solana/kit": "^6.9.0",
    "@solana/kit-plugin-litesvm": "^0.10.0",
    "@solana/kit-plugin-signer": "^0.10.0",
    "@solana/spl-token": "^0.4.14"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
